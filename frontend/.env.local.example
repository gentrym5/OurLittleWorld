# Couple's Website — Frontend Environment Variables
# Copy this file to .env.local and fill in the values.
# .env.local is gitignored and must never be committed.

# Base URL of the Railway-hosted ASP.NET Core API.
# In local development this is typically http://localhost:5000.
# In production this is the Railway-provided URL (e.g. https://couples-api.railway.app).
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000
